generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// NextAuth.js required models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // null for OAuth-only users

  accounts Account[]
  sessions Session[]
  trees    Tree[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Genealogy domain models
// ──────────────────────────────────────────────

model Tree {
  id          String     @id @default(cuid())
  name        String
  description String?
  privacy     TreePrivacy @default(PRIVATE)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  persons Person[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Person {
  id        String  @id @default(cuid())
  firstName String
  lastName  String?
  birthDate DateTime?
  deathDate DateTime?
  birthPlace String?
  gender    Gender?
  bio       String? @db.Text
  photoUrl  String?
  isLiving  Boolean @default(true)

  treeId String
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)

  // Relationships where this person is "person1"
  relationshipsAsSource Relationship[] @relation("RelationshipSource")
  // Relationships where this person is "person2"
  relationshipsAsTarget Relationship[] @relation("RelationshipTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId])
}

model Relationship {
  id   String           @id @default(cuid())
  type RelationshipType

  // The nature of the relationship (biological, adopted, etc.)
  nature RelationshipNature @default(BIOLOGICAL)

  // person1 → person2 direction matters:
  // PARENT_CHILD: person1 is parent, person2 is child
  // SPOUSE: order doesn't matter
  // SIBLING: order doesn't matter
  person1Id String
  person1   Person @relation("RelationshipSource", fields: [person1Id], references: [id], onDelete: Cascade)

  person2Id String
  person2   Person @relation("RelationshipTarget", fields: [person2Id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([person1Id, person2Id, type])
  @@index([person1Id])
  @@index([person2Id])
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum TreePrivacy {
  PRIVATE
  SHARED
  PUBLIC
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RelationshipType {
  PARENT_CHILD
  SPOUSE
  SIBLING
}

enum RelationshipNature {
  BIOLOGICAL
  ADOPTED
  STEP
  FOSTER
}
