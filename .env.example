# Database (PostgreSQL)
# Local: use docker-compose (port 5434)
# Vercel: use Vercel Postgres or Neon — set in Vercel dashboard
DATABASE_URL="postgresql://user:password@localhost:5434/heritree_dev"

# NextAuth.js
# Generate secret: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Set to your production URL on Vercel (e.g. https://heritree.vercel.app)
# Not needed locally — defaults to http://localhost:3000
# AUTH_URL="https://heritree.vercel.app"

# Google OAuth (optional — remove comments to enable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
